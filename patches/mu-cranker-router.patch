+    private MuServer target;
+    private CrankerConnector connector;
+
+    @AfterEach
+    public void cleanup() {
+        if (connector != null) swallowException(() -> connector.stop(5, TimeUnit.SECONDS));
+        if (target != null) swallowException(target::stop);
